VITE_MARKET_API_URL=http://localhost:8002

# Supabase — Project Settings → API (use the anon / public key only)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Market data (backend — server/main.py)
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# AI assistant (backend — server/main.py, never put keys in VITE_* vars)
# Cloud: get key at https://ollama.com — uses https://ollama.com automatically
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma3:4b
# Local Ollama instead: comment out OLLAMA_API_KEY and set:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OAuth (Google / Apple / GitHub): configure via GitHub Actions
# 1. Add secrets listed in .github/oauth-secrets.template
# 2. Run: Actions → "Sync OAuth Providers to Supabase"
# 3. Use callback URL: https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
