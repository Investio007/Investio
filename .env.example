# Local dev: Vite proxies /api → localhost:8002. Production on Vercel: leave unset;
# vercel.json rewrites /api to Railway. Override only for direct cross-origin calls.
# No trailing slash (e.g. https://investio-production.up.railway.app).
VITE_MARKET_API_URL=http://localhost:8002

# Optional: custom OAuth redirect for Capacitor/Android deep links
# VITE_AUTH_REDIRECT_URL=https://your-domain.com/auth/callback
# VITE_AUTH_RESET_REDIRECT_URL=https://your-domain.com/auth/reset-password

# Supabase — Project Settings → API (use the anon / public key only)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Error monitoring (Sentry React project — optional, production recommended)
# VITE_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
# VITE_SENTRY_ENVIRONMENT=production

# Product analytics (PostHog — optional)
# Project Settings → Project API key (starts with phc_)
# VITE_POSTHOG_KEY=phc_your_project_api_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Market data (backend — server/main.py)
# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# AI assistant (backend — server/main.py, never put keys in VITE_* vars)
# Cloud: get key at https://ollama.com — uses https://ollama.com automatically
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma3:4b
# Local Ollama instead: comment out OLLAMA_API_KEY and set:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Backend security (server/main.py)
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-app-domain.com,capacitor://localhost
# ADMIN_API_KEY=generate_a_long_random_secret_for_cache_admin
# AI_RATE_LIMIT=30
# MARKET_RATE_LIMIT=120
# MARKET_RATE_WINDOW=60
# ALPHA_VANTAGE_DAILY_LIMIT=25

# Apple Sign In (frontend — show button when Supabase Apple provider is enabled)
# VITE_APPLE_SIGN_IN_ENABLED=true

# Ionic Appflow CLI (npm run sync:appflow-env — Personal Settings → Personal Access Tokens)
# IONIC_TOKEN=ion_your_personal_access_token

# Error monitoring (backend — Railway; never use VITE_* for Sentry)
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-fastapi-project-id
# SENTRY_ENVIRONMENT=production

# OAuth (Google / Apple / GitHub): configure via GitHub Actions
# 1. Add secrets listed in .github/oauth-secrets.template
# 2. Run: Actions → "Sync OAuth Providers to Supabase"
# 3. Use callback URL: https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
