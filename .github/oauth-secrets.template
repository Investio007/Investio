# Add these in GitHub → Investio007/Investio → Settings → Secrets and variables → Actions

# Required (Supabase Management API)
SUPABASE_ACCESS_TOKEN=     # https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=      # e.g. hqzxlitlibxltvsrqhnj (from your Supabase URL)

# Optional redirect config (defaults shown)
AUTH_SITE_URL=http://localhost:5173
AUTH_REDIRECT_URLS=http://localhost:5173/auth/callback

# Google — https://console.cloud.google.com/apis/credentials
# OAuth client type: Web application
# Authorized redirect URI: https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth App — https://github.com/settings/developers → OAuth Apps → New
# Authorization callback URL: https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Apple — https://developer.apple.com/account/resources/identifiers/list/serviceId
# Services ID + Sign in with Apple key (secret is the generated client secret JWT)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
